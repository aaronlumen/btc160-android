     │             val r = repo.submitFoundKey(puzzle, hexKey, deviceId, address)                                                                                                      │
     │             if (r.confirmed) { confirmed = true; prefs.edit().remove("pending_key_$puzzle").apply() }                                                                           │
     │             else delay(10_000)                                                                                                                                                  │
     │         }                                                                                                                                                                       │
     │     }                                                                                                                                                                           │
     │     // Immediately launch celebration                                                                                                                                           │
     │     _keyFoundEvent.value = puzzle                                                                                                                                               │
