 Implementation details

 api_server.py — new/changed endpoints

 POST /register          → body: {device_id, btc_address, contact}
                           stores in finders.json; returns {registered: true}

 POST /found/{puzzle}    → body: {hex_key, device_id, btc_address}
                           1. verify hex_key derives to puzzle's target address (libsecp256k1 or coincurve)
                           2. check finders.json for dedup (puzzle already claimed → return accepted=false)
                           3. append to found_keys.json with timestamp + device_id
                           4. mark puzzle claimed in claimed.json
                           5. log to stderr: "*** KEY FOUND puzzle={puzzle} key={hex_key} ***"
                           6. (optional hook) call sweep_btc.sh in background
                           return {accepted, confirmed, message}

 WalletManager.kt (new)

 object WalletManager {
     // Generate on first use, store in Android KeyStore (hardware-backed if available)
     fun getOrCreateAddress(context: Context): String  // returns Base58Check address
     fun getDeviceId(context: Context): String         // stable UUID from prefs
 }

